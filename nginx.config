server {
    listen 3002;
    server_name namami-infotech.com www.namami-infotech.com;
    return 301 https://$server_name$request_uri;  # Redirect HTTP to HTTPS
}

server {
    listen 443 ssl;
    server_name namami-infotech.com www.namami-infotech.com;

    ssl_certificate /etc/letsencrypt/live/namami-infotech.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/namami-infotech.com/privkey.pem;

    root /var/www/namami-infotech.com/HRSMILEFRONTEND/build;
    index index.html index.htm;

    location / {
        try_files $uri /index.html;
    }

    location ~* \.(?:ico|css|js|gif|jpe?g|png|woff2?|eot|ttf|svg)$ {
        expires 1y;
        add_header Cache-Control "public";
        try_files $uri /index.html =404;
    }

    error_page 404 /index.html;
}
